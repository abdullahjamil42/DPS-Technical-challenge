# ─────────────────────────────────────────────────────
# Lagovia Train Tracker — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────

# ── Backend ───────────────────────────────────────────

# Port the Express server listens on (default: 3001)
PORT=3001

# Node environment — controls log verbosity and Morgan format
# Values: development | production | test
NODE_ENV=development

# Allowed browser origins for CORS (comma-separated).
# Leave unset in development — defaults to localhost Vite/preview ports.
# Example for production: CORS_ORIGIN=https://yourdomain.com
# CORS_ORIGIN=http://localhost:8080,http://localhost:5173

# iRail API base URL (override only for testing against a mock server)
# IRAIL_BASE_URL=https://api.irail.be

# Rate limiting — requests per IP per window
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=60

# iRail request timeout in milliseconds (default: 8000)
# IRAIL_REQUEST_TIMEOUT_MS=8000

# Station list cache TTL in seconds (default: 3600 = 1 hour)
# STATION_CACHE_TTL_SECONDS=3600

# Liveboard cache TTL in seconds (default: 30)
# LIVEBOARD_CACHE_TTL_SECONDS=30

# ── Frontend (Vite) ───────────────────────────────────

# Override the API base URL (leave empty to use Vite's proxy in development)
# VITE_API_BASE_URL=http://localhost:3001
